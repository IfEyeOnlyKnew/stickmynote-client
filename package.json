{
  "name": "stick-my-note",
  "version": "1.0.0",
  "private": true,
  "description": "A collaborative note-taking application with real-time features",
  "homepage": "https://www.stickmynote.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-username/stick-my-note.git"
  },
  "author": "Stick My Note Team",
  "scripts": {
    "analyze": "ANALYZE=true npm run build",
    "build": "next build",
    "postbuild": "echo 'Build completed successfully'",
    "build:analyze": "ANALYZE=true next build",
    "build:standalone": "BUILD_STANDALONE=true next build",
    "build:windows": "npm run type-check && npm run lint && npm run build",
    "clean": "rm -rf .next out",
    "dev": "next dev",
    "health-check": "curl -f http://localhost:3000/api/health || exit 1",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "start": "node server.js",
    "start:next": "next start",
    "test": "jest",
    "test:build": "npm run type-check && npm run lint && npm run build",
    "test:db": "tsx scripts/test-db-connection.ts",
    "test:rls": "npx tsx tests/rls-unauthorized-access.test.ts",
    "test:security": "npm run test:rls",
    "test:watch": "jest --watch",
    "export:schema": "tsx scripts/export-schema.ts",
    "sql:run": "tsx scripts/run-sql.ts",
    "type-check": "tsc --noEmit"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
