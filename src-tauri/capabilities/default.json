{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability set for Stick My Note desktop app. Grants access to the plugins needed for tray/shortcut UX and stick Library folder-sync (fs watch, dialog, store).",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "notification:default",
    "shell:allow-open",
    "autostart:default",
    "global-shortcut:default",
    "deep-link:default",
    "dialog:default",
    "dialog:allow-open",
    "store:default",
    "fs:default",
    "fs:allow-read-file",
    "fs:allow-read-dir",
    "fs:allow-exists",
    "fs:allow-stat",
    "fs:allow-watch",
    "fs:allow-unwatch",
    {
      "identifier": "fs:scope",
      "allow": [{ "path": "**" }, { "path": "**/*" }]
    }
  ]
}
